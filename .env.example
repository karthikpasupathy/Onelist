# Environment Variables Configuration
# Copy this file to .env.local for local development
# For production, set these in your Vercel project settings

# InstantDB App ID (required unless using local dev auth bypass)
# This is injected into the frontend bundle
VITE_INSTANT_APP_ID=your_instantdb_app_id_here

# Skip magic-code login during `npm run dev` and persist data in localStorage
# Only works in Vite dev mode — ignored in production builds
VITE_DEV_BYPASS_AUTH=false
